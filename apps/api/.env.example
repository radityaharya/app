# Go API
PORT=8080
EXPO_PUSH_URL=https://exp.host/--/api/v2/push/send

# SQLite database file path (relative to the binary)
DB_PATH=commuter.db

# Hermes webhook → WhatsApp (direct delivery route on gateway)
# POST /notifications/send and geofence triggers forward here when set.
# Use the reachable Hermes host (not localhost unless API runs on same machine).
# Example: http://100.x.x.x:8644/webhooks/commuter-app
# Auth: X-Hub-Signature-256: sha256=<hmac-sha256-hex of raw JSON body>
HERMES_WEBHOOK_URL=http://100.101.101.101:8644/webhooks/commuter-app
HERMES_WEBHOOK_SECRET=
